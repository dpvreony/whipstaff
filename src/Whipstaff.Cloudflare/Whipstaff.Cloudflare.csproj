<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <!-- Template Directory setting apparently doesn't work: https://github.com/RicoSuter/NSwag/issues/4244 -->
    <NSwagTemplateDirectory>"$(MSBuildProjectDirectory)\openapi\nswag_templates"</NSwagTemplateDirectory>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="openapi\v4.json" />
    <OpenApiReference Include="openapi\v4.json" Namespace="Whipstaff.Cloudflare.V4" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.ApiDescription.Client" Version="8.0.1">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="NSwag.ApiDescription.Client" Version="14.0.3">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <!-- https://stackoverflow.com/questions/65427466/customize-msbuild-targets-for-the-openapireference-element -->
  <PropertyGroup>
    <OpenApiGenerateCodeOnBuild>false</OpenApiGenerateCodeOnBuild>
    <OpenApiGenerateCodeAtDesignTime>false</OpenApiGenerateCodeAtDesignTime>
  </PropertyGroup>

  <Target Name="DeleteServiceClient">
    <Message Text="------ Custom target: Removing existing generated service client for $(ProjectName)" Importance="high" />
    <Delete Files="$(ProjectDir)$(BaseIntermediateOutputPath)/V4Client.cs" />
  </Target>

  <Target Name="GenerateServiceClient" DependsOnTargets="DeleteServiceClient;GenerateOpenApiCode" BeforeTargets="BeforeCompile" />
</Project>
