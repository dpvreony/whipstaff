<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <Nullable>enable</Nullable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>whipstaff-docfxgen</ToolCommandName>
    <AssemblyName>whipstaff-docfxgen</AssemblyName>
    <PackageDescription>dot net tool to generate a DocFX site using our standard conventions and plugins.</PackageDescription>
    <NoWarn>$(NoWarn),CA1515,NU5104</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="10.0.8" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Whipstaff.CommandLine\Whipstaff.CommandLine.csproj" />
    <ProjectReference Include="..\Whipstaff.Core\Whipstaff.Core.csproj" />
  </ItemGroup>
</Project>
