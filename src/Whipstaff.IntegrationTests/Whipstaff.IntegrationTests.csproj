<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <NoWarn>$(NoWarn),GR0046,GR0049,CA1034,CA1515,CS1591,QA0004</NoWarn>
    <IsTestProject>True</IsTestProject>
    <!-- Disable MSIX packaging and PRI generation on non-Windows platforms -->
    <GenerateAppInstallerFile Condition="!$([MSBuild]::IsOSPlatform('windows'))">false</GenerateAppInstallerFile>
    <AppxPackage Condition="!$([MSBuild]::IsOSPlatform('windows'))">false</AppxPackage>
    <WindowsPackageType Condition="!$([MSBuild]::IsOSPlatform('windows'))">None</WindowsPackageType>
    <AppxGeneratePriEnabled Condition="!$([MSBuild]::IsOSPlatform('windows'))">false</AppxGeneratePriEnabled>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Aspire.Hosting.Testing" Version="13.2.3" />
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" Version="10.0.7" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Whipstaff.Example.AspireAppHost\Whipstaff.Example.AspireAppHost.csproj" IsAspireProjectResource="False" />
    <ProjectReference Include="..\Whipstaff.Example.WebApiApp\Whipstaff.Example.WebApiApp.csproj" IsAspireProjectResource="False" />
    <ProjectReference Include="..\Whipstaff.Example.WebMvcApp\Whipstaff.Example.WebMvcApp.csproj" IsAspireProjectResource="False" />
    <ProjectReference Include="..\Whipstaff.Playwright\Whipstaff.Playwright.csproj" IsAspireProjectResource="False" />
  </ItemGroup>

</Project>
